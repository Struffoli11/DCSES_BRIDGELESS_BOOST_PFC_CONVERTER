  DatatypeOverflowMsg "2"
  DatatypeInheritanceConflictMsg "1"
  ContSampleTimeConflictMsg "1"
  StiffnessDetectionMsg "1"
  MaxConsecutiveZCs "0"
  AlgebraicLoopWithStateMachineMsg "2"
  AssertionAction "1"
  FixedPointDatatypeOverride "1"
  InitializationCommands "% Grid\nVin = 110*sqrt(2); % Grid voltage (V)\nF = 5"
"0.0; % Grid frequency (Hz)\nw= 2*pi*F\n% Plant\nC = 500e-6; % Output capacito"
"r (C)\nL = 1e-3;   % Choke inductance (H)\nRl = 0.02; % Choke resistance (ohm"
"s)\nRo = 125 %Load Resistance (ohms)\n\nfs = 100e3; % Switching frequency (Hz"
")\n\n% Current Compensator\nRi.F = 50e3;       % Current control loop frequen"
"cy (Hz)\nRi.Ts = 1/Ri.F;    % Sample time\nRi.Tp = Ri.Ts/2.0; % Average PWM d"
"elay (s)\n\nRi.Ti = 2/Rl*Ri.Tp; \nRi.Tn = L/Rl;\n\nRi.Kp = Ri.Tn/Ri.Ti;\nRi.K"
"i = 1/Ri.Ti;\n\n% Voltage Compensator\nRv.F = 2e3;         % Voltage control "
"loop frequency (Hz)\nRv.Ts = 1/Rv.F; \t  % Sample time\nRv.Tp = Rv.Ts/2*10; %"
" Equivalent delay\n\nRv.Ti = 8/C*Rv.Tp*Rv.Tp;\nRv.Tn = 4*Rv.Tp;\n\nRv.Kp = Rv"
".Tn/Rv.Ti;\nRv.Ki = 1/Rv.Ti;\n\n%parametri articolo\nGm_cv =  0.026; %Outer--"
"loop dc gain\nfz_cv = 66.78; %Zero-Frequency (Hz)\nwz_cv = fz_cv * (2 * pi); "
"%natural frequency \nKc = 0.002%controller inner loop gain\nFswc = 100e3 %swi"
"tch frequency"
