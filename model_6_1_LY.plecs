  InitializationCommands "% Grid\nVin = 110*sqrt(2); % Grid voltage (V)\nF = 5"
"0.0; % Grid frequency (Hz)\n\n% Plant\nC = 500e-6; % Output capacitor (C)\nL "
"= 1e-3;   % Choke inductance (H)\nRl = 0.02; % Choke resistance (ohms)\nRo = "
"125 %Load Resistance (ohms)\n\nfs = 100e3; % Switching frequency (Hz)\n\n% Cu"
"rrent Compensator\nRi.F = 100e3;       % Current control loop frequency (Hz)"
"\nRi.Ts = 1/Ri.F;    % Sample time\nRi.Tp = Ri.Ts/2.0; % Average PWM delay (s"
")\n\nRi.Ti = 2/Rl*Ri.Tp; \nRi.Tn = L/Rl;\n\nRi.Kp = Ri.Tn/Ri.Ti;\nRi.Ki = 1/R"
"i.Ti;\n\n% Voltage Compensator\nRv.F = 2e3;         % Voltage control loop fr"
"equency (Hz)\nRv.Ts = 1/Rv.F; \t  % Sample time\nRv.Tp = Rv.Ts/2*10; % Equiva"
"lent delay\n\nRv.Ti = 8/C*Rv.Tp*Rv.Tp;\nRv.Tn = 4*Rv.Tp;\n\nRv.Kp = Rv.Tn/Rv."
"Ti;\nRv.Ki = 1/Rv.Ti;\n\n%parametri articolo\nGm_cv =  0.026; %Outer--loop dc"
" gain\nfz_cv = 66.78; %Zero-Frequency (Hz)\nwz_cv = fz_cv * (2 * pi); %natura"
"l frequency \nKc = 0.002%controller inner loop gain\nFswc = 100e3 %switch fre"
"quency"
